# Copia este archivo a .env y completa los valores

# Django
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga
DEBUG=True

# Hosts permitidos (separados por coma)
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Base de datos local (no se usa si DATABASE_URL está definida)
DB_NAME=ctmagic
DB_USER=postgres
DB_PASSWORD=tu_password
DB_HOST=127.0.0.1
DB_PORT=5432

# En producción Render inyecta esto automáticamente — no completar manualmente
# DATABASE_URL=postgres://user:password@host:5432/dbname
